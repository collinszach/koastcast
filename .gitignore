# Secrets — never commit
.env
.env.local
.env.*.local
*.key
*.pem
# Nginx certs (auto-generated at container startup)
nginx/certs/*.pem
nginx/certs/*.crt
nginx/certs/*.key
nginx/certs/*.der
nginx/certs/*
!nginx/certs/.gitkeep
venv/
__pycache__/
*.pyc
.next/
node_modules/

# Large model / data files — never commit to git
models/*.gguf
models/*.bin
models/*.safetensors
data/ndbc_historical/
data/bathymetry/
data/swan_configs/
*.parquet
*.pkl
supabase/.temp/

# ─── Proprietary / Not for public repo ───────────────────────────────────────
# Tuned scoring weights (calibrated from 9 years of session data — not public)
apps/api/scoring/weights.py

# Spot database with proprietary buoy mappings + optimal conditions research
data/spots.private.json

# ML training scripts (feature engineering + training pipeline is proprietary IP)
# The inference code in apps/api/services/bias_correction.py is public;
# the training pipeline that produces the .pkl models is not.
ml/

# Internal AI-assisted planning/spec documents
docs/superpowers/

# Memory files (local Claude context)
.claude/

# Portfolio / marketing screenshots (may contain real user data)
portfolio-screenshots/

# Internal planning, competitive research, and AI-assisted spec documents
SURFER_RESEARCH.md
TASKS.md
V2.md
PROMPT_PHASE*.md

# OS / editor
.DS_Store
*.swp
*.swo
.idea/
.vscode/
