# ─── SwellStack Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ─── NOAA Tides API ───────────────────────────────────────────────────────────
# Free registration at: https://tidesandcurrents.noaa.gov/
NOAA_TIDES_API_KEY=

# ─── Open-Meteo ───────────────────────────────────────────────────────────────
# For dev: uses open-meteo.com directly. For production: self-hosted Docker.
OPEN_METEO_BASE_URL=http://localhost:8080

# ─── LLM (llama.cpp / Phi-4-mini) ────────────────────────────────────────────
LLAMA_CPP_BASE_URL=http://localhost:8081/v1
MODEL_PATH=/models/phi-4-mini-q4_k_m.gguf

# ─── FUTURE INTEGRATION: Cloudflare Tunnel ────────────────────────────────────
# Disabled for local development — API runs directly on localhost:8000.
# Uncomment and set token to expose the API via Cloudflare Tunnel in production.
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── API Settings ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# CORS: comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://swellstack.io

# ─── Next.js / Vercel (apps/web/.env.local) ───────────────────────────────────
# These go in apps/web/.env.local, not here
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# NUC_API_BASE_URL=https://api.swellstack.io
# NUC_API_SECRET=...
# NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json
# STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET=...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
