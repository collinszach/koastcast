# ─── Peakcast Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control — it's in .gitignore.
#
# QUICK START (local dev, no Supabase):
#   cp .env.example .env
#   # Leave Supabase/Stripe blank — app runs on local JSON + public APIs
#   docker compose up -d

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
# Leave blank for local dev — app falls back to local JSON files gracefully.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
# Required for JWT signature verification — Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ─── NOAA Tides API ───────────────────────────────────────────────────────────
# Free registration at: https://tidesandcurrents.noaa.gov/
# Leave blank — tides still work with the public endpoint (rate-limited).
NOAA_TIDES_API_KEY=

# ─── Open-Meteo ───────────────────────────────────────────────────────────────
# Self-hosted Docker container (docker-compose service name) for surf forecasts:
OPEN_METEO_BASE_URL=http://open-meteo-api:8080
# Public API fallback for weather/trail forecasts (no self-hosting needed):
OPEN_METEO_FORECAST_BASE_URL=https://api.open-meteo.com

# ─── LLM (Ollama — AskPeak natural language queries) ─────────────────────────
# Ollama runs in Docker (docker-compose service: llm, port 11434)
LLAMA_CPP_BASE_URL=http://llm:11434/v1
# Model: phi4-mini (2.5GB) — pull with: docker exec peakcast_llm ollama pull phi4-mini
# Ollama model name used in services/llm.py:
OLLAMA_MODEL=phi4-mini

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# For production, set this to your deployed frontend URL.
# Example: CORS_ORIGINS=https://nSwell.zacharyjcollins.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that can access the /admin dashboard.
# Set this in your Vercel environment variables.
ADMIN_EMAILS=you@yourdomain.com

# ─── Stripe (payment gating — leave blank for dev) ────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Exposes NUC to the internet at nSwell.zacharyjcollins.com — no open ports needed.
# Get token from: Cloudflare Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# ─── Email / SMTP (Supabase custom SMTP) ──────────────────────────────────────
# Supabase free tier: 3 emails/hour max, often lands in spam.
# Configure in: Supabase Dashboard → Project Settings → Authentication → SMTP
# These values are NOT read by the app — paste them directly into the Supabase dashboard.
# See RUNBOOK.md section 14 for full setup instructions.
#
# Option A — Gmail / Google Workspace (easiest if you have Google account):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password-here   # 16-char App Password from myaccount.google.com
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=Peakcast
#
# Option B — Resend (best for production + custom domain):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Peakcast

# ─── Next.js / Vercel (apps/web/.env.local) ───────────────────────────────────
# These go in apps/web/.env.local — NOT here.
# Create apps/web/.env.local with:
#
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# NUC_API_BASE_URL=http://localhost:8002                   # dev
# NUC_API_BASE_URL=https://nSwell.zacharyjcollins.com     # prod (Cloudflare Tunnel)
# NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
